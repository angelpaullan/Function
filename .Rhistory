# ===============================
# 1. FUNCIÓN DE DENSIDAD
# ===============================
f <- function(x) {
ifelse(x >= 0 & x <= 2, (3/4) * x * (2 - x)^2, 0)
}
# ===============================
# 2. FUNCIÓN ACUMULADA (CDF)
# ===============================
Fdist <- function(x) {
ifelse(x < 0, 0,
ifelse(x > 2, 1,
(3/2)*x^2 - x^3 + (3/16)*x^4))
}
# ===============================
# 3. NEWTON-RAPHSON (FUNCIÓN PROPIA)
# ===============================
newton_raphson <- function(u, x0 = 1, tol = 1e-6, max_iter = 100) {
x <- x0
for(i in 1:max_iter) {
Fx <- (3/2)*x^2 - x^3 + (3/16)*x^4
fx <- (3/4)*x*(2 - x)^2
x_new <- x - (Fx - u) / fx
# Control de dominio
if(x_new < 0) x_new <- 0
if(x_new > 2) x_new <- 2
# Criterio de convergencia
if(abs(x_new - x) < tol) {
return(x_new)
}
x <- x_new
}
return(x)
}
# ===============================
# 4. GENERADOR DE DATOS
# ===============================
random_NR <- function(n) {
u <- runif(n)
sapply(u, function(ui) newton_raphson(ui))
}
# ===============================
# 5. SIMULACIÓN
# ===============================
set.seed(123)
muestra <- random_NR(1000)
# ===============================
# 6. HISTOGRAMA + DENSIDAD
# ===============================
hist(muestra, probability = TRUE, col = "lightblue",
main = "Histograma vs Densidad Teórica",
xlab = "x")
curve((3/4)*x*(2-x)^2,
col = "red",
add = TRUE,
lwd = 2)
# ===============================
# 7. CDF EMPÍRICA VS TEÓRICA
# ===============================
plot(ecdf(muestra),
main = "CDF Empírica vs Teórica",
xlab = "x",
ylab = "F(x)")
curve((3/2)*x^2 - x^3 + (3/16)*x^4,
col = "red",
add = TRUE,
lwd = 2)
legend("bottomright",
legend = c("Empírica", "Teórica"),
col = c("black", "red"),
lwd = 2)
# ===============================
# 8. PROBABILIDADES
# ===============================
pprob <- function(a, b) {
Fdist(b) - Fdist(a)
}
pprob(0.5, 1.5)
# ===============================
# 9. TABLA DE FRECUENCIAS
# ===============================
library(fdth)
tfr <- fdt(muestra, start = 0, end = 2, h = 0.2)
fa <- tfr$table$f
# ===============================
# 10. PROBABILIDADES TEÓRICAS
# ===============================
pfx <- function(q) {
if(q >= 2) return(1)
integrate(f, 0, q)$value
}
vals <- c(seq(0, 1.8, 0.2), 2)
prbs <- numeric(length(vals))
for(i in 1:length(vals)) {
prbs[i] <- pfx(vals[i])
}
probabilidades <- diff(prbs)
# ===============================
# 11. PRUEBA CHI-CUADRADO
# ===============================
pr_bond_ajus <- function(fa, probs) {
n <- sum(fa)
E <- n * probs
STATISTIC <- sum((fa - E)^2 / E)
PARAMETER <- length(fa) - 1
PVAL <- pchisq(STATISTIC, PARAMETER, lower.tail = FALSE)
list(
X2 = STATISTIC,
gl = PARAMETER,
p_value = PVAL
)
}
resultado<- pr_bond_ajus(fa, probabilidades)
as.data.frame(resultado)
