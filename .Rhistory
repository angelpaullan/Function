f <- function(x) {
ifelse(x >= 0 & x <= 2, (3/4) * x * (2 - x)^2, 0)
}
# 2. Verificar que la integral en todo el dominio es 1
integrate(f, lower = 0, upper = 2)
#####ajuste de bondad
library(fdth)
# Tabla de frecuencias con el dominio completo [0, 2]
tfr <- fdt(muestra, start = 0, end = 2, h = 0.2)
# Frecuencias absolutas
fa <- tfr$table$f
# Puntos de corte hasta el dominio completo
vals <- c(seq(0, 1.8, 0.2), 2)  # De 0 a 2, cada 0.2
# Probabilidades teóricas
prbs <- numeric(length(vals))
for(i in 1:length(vals)) {
prbs[i] <- pfx(vals[i])
}
probabilidades <- diff(prbs)
sum(probabilidades)
