fa <- tfr$table$f
# pfx calcula P(X < x) usando integrate
pfx <- function(q) {
if(q >= 2) return(1)
integrate(f, 0, q)$value
}
# Puntos de corte hasta el dominio completo
vals <- c(seq(0, 1.8, 0.2), 2)  # De 0 a 2, cada 0.2
# Probabilidades teóricas
prbs <- numeric(length(vals))
for(i in 1:length(vals)) {
prbs[i] <- pfx(vals[i])
}
probabilidades <- diff(prbs)
sum(probabilidades)
pr_bond_ajus(fa,probabilidades)
