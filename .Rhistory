fchisq <- function(sample) {
x <- seq(-1, 2, by = 0.25)
fx <- diff(pf(x))
t <- fdt(sample, start = -1, end = 2, h = 0.25)
fa <- t$table$f
res <- chisq.test(x = fa, p = fx)
c("statistic" = as.numeric(res$statistic),
"df"        = as.numeric(res$parameter),
"p.val"     = res$p.value)
}
fchisq(muestra)
