fchisq <- function(muestra) {
x <- seq(-1, 2, by = 0.25)
fx <- diff(pfun(x))
t <- fdt(muestra, start = -1, end = 2, h = 0.25)
fa <- t$table$f
res <- chisq.test(x = fa, p = fx)
c("statistic" = as.numeric(res$statistic),
"df"        = as.numeric(res$parameter),
"p.val"     = res$p.value)
}
fchisq <- function(x) {
x <- seq(-1, 2, by = 0.25)
fx <- diff(pfun(x))
t <- fdt(x, start = -1, end = 2, h = 0.25)
fa <- t$table$f
res <- chisq.test(x = fa, p = fx)
c("statistic" = as.numeric(res$statistic),
"df"        = as.numeric(res$parameter),
"p.val"     = res$p.value)
}
muestra <- randomfun(1000)
fchisq(muestra)
