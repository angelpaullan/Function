rown <- function(n){
u <- runif(n)
sign(9*u - 1) * abs(9*u - 1)^(1/3)
}
rown(1000)
pown <- function(x){
ifelse(x <= -1, 0,
ifelse(x < 2, (x^3 + 1)/9, 1))
}
pown
pown(0)
pown(c(-1, 0, 1, 2))
